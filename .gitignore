# Python cache
__pycache__/
*.py[cod]

# Large model files
*.safetensors
*.ckpt
*.pt
*.pth
*.bin

# Raw/private/generated project data
outputs/
video_frames/
face_crops/
logs/
video_inputs/
character_refs/
body_refs/
pose_refs/

# Keep empty directory placeholders
!outputs/.gitkeep
!video_frames/.gitkeep
!face_crops/.gitkeep
!logs/.gitkeep
!video_inputs/.gitkeep
!character_refs/.gitkeep
!body_refs/.gitkeep
!pose_refs/.gitkeep

# Workflows are source assets and should be tracked.
workflows/*
!workflows/.gitkeep
!workflows/README.md
!workflows/**/*.json
