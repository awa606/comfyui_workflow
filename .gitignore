# Python cache
__pycache__/
*.py[cod]

# Large model files
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
*.onnx

# Raw/private/generated project data
outputs/
video_frames/
face_crops/
logs/
video_inputs/
character_refs/
body_refs/
pose_refs/
datasets/
model_tests/

# Character source media and generated triage outputs
characters/**/*.png
characters/**/*.jpg
characters/**/*.jpeg
characters/**/*.webp
characters/**/*.bmp
characters/**/*.tif
characters/**/*.tiff
characters/**/*.mp4
characters/**/*.mov
characters/**/*.avi
characters/**/*.mkv
characters/**/*.webm
characters/**/*.m4v
characters/**/*.wmv
characters/**/metadata/*.csv
!characters/
!characters/**/
!characters/**/.gitkeep

# Keep empty directory placeholders
!outputs/.gitkeep
!video_frames/.gitkeep
!face_crops/.gitkeep
